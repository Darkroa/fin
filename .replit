modules = ["nodejs-20", "python-3.12", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "ffmpeg-full", "freetype", "glibcLocales", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tk", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 3003

[[ports]]
localPort = 5004
externalPort = 3002

[[ports]]
localPort = 5005
externalPort = 4200

[[ports]]
localPort = 5006
externalPort = 5000

[[ports]]
localPort = 5007
externalPort = 5173

[[ports]]
localPort = 5008
externalPort = 6000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8088
externalPort = 3000

[userenv]

[userenv.shared]
API_BASE_URL = "http://localhost:8000/api"
REDIS_URL = "redis://localhost:6379/0"
REDIS_RESULT_BACKEND = "redis://localhost:6379/1"
SLACK_CHANNEL = "#trading-alerts"
CELERY_TASK_ALWAYS_EAGER = "false"
JWT_SECRET_KEY = "finai-jwt-secret-replit-2024-secure"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd /home/runner/workspace && uvicorn src.api.main:app --host 0.0.0.0 --port 8080"]
build = ["sh", "-c", "cd /home/runner/workspace/frontend && npm install --legacy-peer-deps && npm run build"]
