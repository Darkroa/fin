modules = ["nodejs-20", "python-3.12", "bash", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "ffmpeg-full", "freetype", "glibcLocales", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tk", "typescript", "xcodebuild", "zlib", "eas-cli"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001

[[ports]]
localPort = 8000

[[ports]]
localPort = 8050

[[ports]]
localPort = 8080

[[ports]]
localPort = 8081

[[ports]]
localPort = 23636
externalPort = 3000

[userenv]

[userenv.shared]
API_BASE_URL = "http://localhost:8000/api"
REDIS_URL = "redis://localhost:6379/0"
REDIS_RESULT_BACKEND = "redis://localhost:6379/1"
SLACK_CHANNEL = "#trading-alerts"
CELERY_TASK_ALWAYS_EAGER = "false"
JWT_SECRET_KEY = "finai-jwt-secret-replit-2024-secure"
EVOLUTION_API_URL = "http://localhost:8080"
EVOLUTION_INSTANCE = "FinAiEvobots"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "cd /home/runner/workspace && PYTHONPATH=/home/runner/workspace PATH=/home/runner/workspace/.pythonlibs/bin:$PATH python3 -m uvicorn src.api.main:app --host 0.0.0.0 --port 5000"]
build = ["sh", "-c", "cd /home/runner/workspace/frontend && npm install --legacy-peer-deps && npm run build"]
